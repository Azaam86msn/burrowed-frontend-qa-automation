# ========================
# Environment Configuration
# ========================
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.

# Frontend (Cypress)
CYPRESS_BASE_URL=https://burrowed.org

# Backend API
API_BASE_URL=https://burrowed-magazine-api.onrender.com/api

# AI analysis scripts (optional — only needed for pnpm ai:* commands)
GEMINI_API_KEY=your_gemini_api_key_here
