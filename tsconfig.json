{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["cypress", "node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["cypress.config.ts", "cypress/**/*.ts"],
  "exclude": ["node_modules"]
}
