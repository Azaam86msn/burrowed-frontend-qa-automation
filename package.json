{
  "name": "burrowed-frontend-qa-automation",
  "version": "1.0.0",
  "description": "Frontend QA Automation for Burrowed Magazine — Cypress + Allure + Docker",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:smoke": "cypress run --spec 'cypress/e2e/smoke/*.cy.ts'",
    "cypress:regression": "cypress run --spec 'cypress/e2e/regression/**/*.cy.ts'",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clear": "node -e \"['allure-results','allure-report'].forEach(d=>{try{require('fs').rmSync(d,{recursive:true,force:true})}catch{}})\"",
    "docker:up": "docker compose up --exit-code-from cypress",
    "docker:down": "docker compose down --remove-orphans",
    "ai:analyze": "node scripts/ai-analyze.mjs --mode analyze-failure",
    "ai:flaky": "node scripts/ai-analyze.mjs --mode detect-flaky",
    "ai:locator": "node scripts/ai-analyze.mjs --mode suggest-locator-fix",
    "ai:generate": "node scripts/ai-analyze.mjs --mode generate-test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cypress"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "allure-commandline": "^2.30.0",
    "allure-cypress": "^3.2.0",
    "cypress": "^15.14.2",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@11.0.9"
}
